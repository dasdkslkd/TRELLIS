{
    "_comment": "Sparse Structure VAE Stage1 occupancy-calibrated finetune on ABC-1M voxelized BRep",
    "_description": "Continue from ABC-1M stage1 v2 best EMA checkpoint with Tversky-style occupancy overlap loss and a small LR to improve miou_occ without the v2 recall drop becoming too severe.",
    "models": {
        "encoder": {
            "name": "SparseStructureEncoder",
            "args": {
                "in_channels": 80,
                "latent_channels": 8,
                "num_res_blocks": 2,
                "num_res_blocks_middle": 2,
                "channels": [32, 128, 512],
                "use_fp16": false
            }
        },
        "decoder_stage1": {
            "name": "SparseStructureDecoder",
            "args": {
                "out_channels": 8,
                "latent_channels": 8,
                "num_res_blocks": 2,
                "num_res_blocks_middle": 2,
                "channels": [512, 128, 32],
                "use_fp16": false
            }
        }
    },
    "dataset": {
        "name": "CustomSparseStructure",
        "args": {
            "resolution": 64
        }
    },
    "val_dataset": {
        "name": "CustomSparseStructure",
        "args": {
            "resolution": 64
        }
    },
    "trainer": {
        "name": "TwoStageSparseStructureVaeTrainer",
        "args": {
            "training_mode": "stage1",
            "stage1_channels": 8,
            "stage2_channels": 72,
            "lambda_dice": 1.5,
            "occupancy_overlap_loss": "tversky",
            "tversky_alpha": 0.65,
            "tversky_beta": 0.35,
            "lambda_bce_occ": 1.45,
            "occ_bce_pos_weight": 6.5,
            "lambda_ce": 1.8,
            "lambda_mse": 0.0,
            "lambda_kl": 0.00001,
            "detach_stage1_for_stage2": true,
            "stage2_cond_source": "predicted",
            "max_steps": 1200,
            "batch_size_per_gpu": 1,
            "batch_split": 1,
            "num_workers": 0,
            "persistent_workers": false,
            "best_metric": "miou_occ",
            "best_metric_mode": "max",
            "optimizer": {
                "name": "AdamW",
                "args": {
                    "lr": 0.000015,
                    "weight_decay": 0.0
                }
            },
            "lr_scheduler": {
                "name": "CosineAnnealingLR",
                "args": {
                    "T_max": 1200,
                    "eta_min": 0.0000015
                }
            },
            "finetune_ckpt": {
                "encoder": "/public/home/pb22000140/TRELLIS-new/TRELLIS-main/outputs/vae/abc1m_stage1_v2/ckpts/encoder_ema0.9999_step0001050.pt",
                "decoder_stage1": "/public/home/pb22000140/TRELLIS-new/TRELLIS-main/outputs/vae/abc1m_stage1_v2/ckpts/decoder_stage1_ema0.9999_step0001050.pt"
            },
            "ema_rate": [0.9999],
            "fp16_mode": null,
            "fp16_scale_growth": 0.001,
            "grad_clip": {
                "name": "AdaptiveGradClipper",
                "args": {
                    "max_norm": 0.5,
                    "clip_percentile": 95
                }
            },
            "i_log": 50,
            "i_sample": 300,
            "i_save": 200
        }
    }
}