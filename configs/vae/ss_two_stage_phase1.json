{
    "_comment": "Two-Stage Sparse Structure VAE - Phase 1 (Stage 1 Only)",
    "_description": "Train encoder + stage1 decoder only. Reconstructs channels 0-7 (occupancy + one-hot categories). decoder_stage2 is included but frozen.",
    "models": {
        "encoder": {
            "name": "SparseStructureEncoder",
            "args": {
                "in_channels": 83,
                "latent_channels": 8,
                "num_res_blocks": 2,
                "num_res_blocks_middle": 2,
                "channels": [32, 128, 512],
                "use_fp16": false
            }
        },
        "decoder_stage1": {
            "name": "SparseStructureDecoder",
            "args": {
                "out_channels": 8,
                "latent_channels": 8,
                "num_res_blocks": 2,
                "num_res_blocks_middle": 2,
                "channels": [512, 128, 32],
                "use_fp16": false
            }
        },
        "decoder_stage2": {
            "name": "SparseStructureCondDecoder",
            "args": {
                "out_channels": 75,
                "latent_channels": 8,
                "cond_channels": 8,
                "cond_latent_channels": 32,
                "num_res_blocks": 2,
                "num_res_blocks_middle": 2,
                "channels": [512, 128, 32],
                "use_fp16": false
            }
        }
    },
    "dataset": {
        "name": "CustomSparseStructure",
        "args": {
            "resolution": 64
        }
    },
    "val_dataset": {
        "name": "CustomSparseStructure",
        "args": {
            "resolution": 64
        }
    },
    "trainer": {
        "name": "TwoStageSparseStructureVaeTrainer",
        "args": {
            "training_mode": "stage1",
            "stage1_channels": 8,
            "stage2_channels": 75,
            "lambda_dice": 1.0,
            "lambda_ce": 1.0,
            "lambda_mse": 1.0,
            "lambda_kl": 0.001,
            "max_steps": 60000,
            "batch_size_per_gpu": 1,
            "batch_split": 1,
            "optimizer": {
                "name": "AdamW",
                "args": {
                    "lr": 1e-3,
                    "weight_decay": 0.0
                }
            },
            "ema_rate": [0.9999],
            "fp16_mode": null,
            "fp16_scale_growth": 0.001,
            "grad_clip": {
                "name": "AdaptiveGradClipper",
                "args": {
                    "max_norm": 1.0,
                    "clip_percentile": 95
                }
            },
            "i_log": 500,
            "i_sample": 1000,
            "i_save": 1000
        }
    }
}
